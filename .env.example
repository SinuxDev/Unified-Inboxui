# NestJS API (server-side only — never expose secrets with NEXT_PUBLIC_)
API_URL=http://localhost:3001

# Browser origins allowed for mutating BFF routes (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# Cookie settings
SESSION_COOKIE_NAME=inbox_session
REFRESH_COOKIE_NAME=inbox_refresh
# Set to true behind HTTPS; also forced when NODE_ENV=production
SESSION_COOKIE_SECURE=false
